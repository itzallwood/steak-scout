# Copy this file to .env and fill in your values.
# Never commit .env to git.

ANTHROPIC_API_KEY=your_key_here

# Kroger Developer API — used for Harris Teeter scraper
# Register free at https://developer.kroger.com → Create Application (Confidential)
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# Harris Teeter store location ID (default: Mayfaire, Wilmington NC = 01600370)
# Find your store: GET https://api.kroger.com/v1/locations?filter.chain=HARRIS-TEETER&filter.zipCode=YOUR_ZIP
KROGER_LOCATION_ID=09700210
